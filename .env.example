DATABASE_URL="postgresql://postgres:password@localhost:5432/clipscash?schema=public"

# NFT / Royalty config
# Basis points: 100 bps = 1%
CREATOR_ROYALTY_BPS=1000        # 10% to the clip creator
PLATFORM_ROYALTY_BPS=100        # 1%  to ClipCash platform
PLATFORM_WALLET_ADDRESS=        # ClipCash treasury wallet (Stellar / Solana)

# Blockchain RPC (Stellar Soroban or Solana)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet
